# === Database ===
# Share the existing FZR Postgres container; create a dedicated DB + user.
DATABASE_URL=postgresql://datev_user:CHANGE_ME@postgres:5432/datev_buchhaltung

# === Auth (must match FZR backend for shared JWT) ===
SECRET_KEY=must-match-FZR-SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_COOKIE_NAME=fz_access_token

# === CORS ===
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://admin.froehlichdienste.de,http://localhost:3000

# === FZR backend (for service-to-service calls — later phases) ===
FZR_API_BASE_URL=http://backend:8000
FZR_SERVICE_USER_EMAIL=
FZR_SERVICE_USER_PASSWORD=

# === Logging / Observability ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Runtime ===
ENVIRONMENT=production
